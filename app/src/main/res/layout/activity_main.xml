<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Encabezado de la App -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="24dp" />

        <!-- Tarjeta: Servicio de Segundo Plano -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/service_active_label"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/service_active_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_service"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@color/primary"
                app:trackTint="@color/card_border" />
        </LinearLayout>

        <!-- Botón de Acción Rápida -->
        <android.widget.Button
            android:id="@+id/btn_change_now"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_button_gradient"
            android:text="@string/btn_change_now"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:elevation="4dp"
            android:layout_marginBottom="24dp" />

        <!-- Control de Pestañas (Inicio vs Bloqueo) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_tabs_container"
            android:padding="4dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tab_home"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/tab_home"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_tab_active"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tab_lock"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/tab_lock"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@color/transparent"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Contenedor Principal de Opciones -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- CONFIGURACIÓN PANTALLA DE INICIO -->
            <LinearLayout
                android:id="@+id/layout_home_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Tarjeta: Estado de Pausa de Rotación (v0.3) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="12dp">

                        <TextView
                            android:id="@+id/tv_home_status_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rotación automática"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_home_status_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="La imagen cambiará automáticamente"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_home_active"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/secondary"
                        app:trackTint="@color/card_border" />
                </LinearLayout>

                <!-- Tarjeta 1: Carpeta de Origen -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lbl_folder"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_home_folder_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_folder_selected"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginTop="8dp"
                        android:ellipsize="middle"
                        android:singleLine="true" />

                    <TextView
                        android:id="@+id/tv_home_image_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 imágenes encontradas"
                        android:textColor="@color/secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp" />

                    <android.widget.Button
                        android:id="@+id/btn_home_select_folder"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_card"
                        android:text="@string/btn_select_folder"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textAllCaps="false" />
                </LinearLayout>

                <!-- Tarjeta 2: Disparador -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lbl_trigger"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rg_home_trigger"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rb_home_trigger_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/trigger_time"
                            android:textColor="@color/text_primary"
                            android:buttonTint="@color/primary"
                            android:checked="true" />

                        <RadioButton
                            android:id="@+id/rb_home_trigger_unlock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/trigger_unlock"
                            android:textColor="@color/text_primary"
                            android:buttonTint="@color/primary" />
                    </RadioGroup>

                    <!-- Selector de Intervalo (Visible solo si se elige Tiempo) -->
                    <LinearLayout
                        android:id="@+id/layout_home_interval"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/lbl_interval"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                        <Spinner
                            android:id="@+id/spinner_home_interval"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_card"
                            android:spinnerMode="dropdown" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Tarjeta 3: Ajuste de Imagen -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lbl_fit_mode"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rg_home_fit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rb_home_fit_fill"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/fit_fill"
                            android:textColor="@color/text_primary"
                            android:buttonTint="@color/primary"
                            android:checked="true" />

                        <RadioButton
                            android:id="@+id/rb_home_fit_stretch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/fit_stretch"
                            android:textColor="@color/text_primary"
                            android:buttonTint="@color/primary" />

                        <RadioButton
                            android:id="@+id/rb_home_fit_fit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/fit_fit"
                            android:textColor="@color/text_primary"
                            android:buttonTint="@color/primary" />
                    </RadioGroup>

                    <!-- Checkbox: No recortar (para paralaje / desplazamiento lateral) -->
                    <CheckBox
                        android:id="@+id/cb_home_crop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/crop_wallpaper"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:buttonTint="@color/primary"
                        android:checked="true"
                        android:layout_marginTop="10dp"
                        android:visibility="visible" />
                </LinearLayout>

                <!-- Tarjeta 4: Brillo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lbl_brightness"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_home_brightness_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Brillo: 100% (Original)"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp" />

                    <SeekBar
                        android:id="@+id/sb_home_brightness"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="100"
                        android:thumbTint="@color/secondary"
                        android:progressTint="@color/secondary"
                        android:progressBackgroundTint="@color/card_border" />
                </LinearLayout>

                <!-- Tarjeta 5: Orden de Selección -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lbl_order"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rg_home_order"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rb_home_order_random"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/order_random"
                            android:textColor="@color/text_primary"
                            android:buttonTint="@color/primary"
                            android:checked="true" />

                        <RadioButton
                            android:id="@+id/rb_home_order_sequential"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/order_sequential"
                            android:textColor="@color/text_primary"
                            android:buttonTint="@color/primary" />
                    </RadioGroup>
                </LinearLayout>

                <!-- Tarjeta 6: Mock Phone Live Preview -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card"
                    android:padding="20dp"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lbl_preview"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <FrameLayout
                        android:layout_width="160dp"
                        android:layout_height="290dp"
                        android:background="@drawable/bg_phone_mock"
                        android:padding="6dp">

                        <!-- Contenedor interno redondeado para recortar la imagen de fondo -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:cardCornerRadius="26dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/black">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <!-- La imagen cargada -->
                                <ImageView
                                    android:id="@+id/iv_home_preview"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    tools:src="@android:drawable/ic_menu_gallery" />

                                <!-- Filtro de atenuación de brillo en tiempo real -->
                                <View
                                    android:id="@+id/view_home_preview_dim"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@color/black"
                                    android:alpha="0.0" />

                                <!-- Widgets de prueba del mock phone -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:gravity="center_horizontal"
                                    android:layout_marginTop="28dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="12:00"
                                        android:textColor="@color/white"
                                        android:textSize="26sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Martes, 2 de Junio"
                                        android:textColor="@color/white"
                                        android:textSize="10sp"
                                        android:alpha="0.8" />
                                </LinearLayout>
                            </FrameLayout>
                        </androidx.cardview.widget.CardView>
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- CONFIGURACIÓN PANTALLA DE BLOQUEO -->
            <LinearLayout
                android:id="@+id/layout_lock_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Tarjeta: Estado de Pausa de Rotación (v0.3) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="12dp">

                        <TextView
                            android:id="@+id/tv_lock_status_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rotación automática"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_lock_status_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="La imagen cambiará automáticamente"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_lock_active"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/secondary"
                        app:trackTint="@color/card_border" />
                </LinearLayout>

                <!-- Tarjeta 1: Carpeta de Origen -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lbl_folder"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_lock_folder_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_folder_selected"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginTop="8dp"
                        android:ellipsize="middle"
                        android:singleLine="true" />

                    <TextView
                        android:id="@+id/tv_lock_image_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 imágenes encontradas"
                        android:textColor="@color/secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp" />

                    <android.widget.Button
                        android:id="@+id/btn_lock_select_folder"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_card"
                        android:text="@string/btn_select_folder"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textAllCaps="false" />
                </LinearLayout>

                <!-- Tarjeta 2: Disparador -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lbl_trigger"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rg_lock_trigger"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rb_lock_trigger_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/trigger_time"
                            android:textColor="@color/text_primary"
                            android:buttonTint="@color/primary"
                            android:checked="true" />

                        <RadioButton
                            android:id="@+id/rb_lock_trigger_unlock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/trigger_unlock"
                            android:textColor="@color/text_primary"
                            android:buttonTint="@color/primary" />
                    </RadioGroup>

                    <!-- Selector de Intervalo (Visible solo si se elige Tiempo) -->
                    <LinearLayout
                        android:id="@+id/layout_lock_interval"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/lbl_interval"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                        <Spinner
                            android:id="@+id/spinner_lock_interval"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_card"
                            android:spinnerMode="dropdown" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Tarjeta 3: Ajuste de Imagen -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lbl_fit_mode"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rg_lock_fit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rb_lock_fit_fill"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/fit_fill"
                            android:textColor="@color/text_primary"
                            android:buttonTint="@color/primary"
                            android:checked="true" />

                        <RadioButton
                            android:id="@+id/rb_lock_fit_stretch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/fit_stretch"
                            android:textColor="@color/text_primary"
                            android:buttonTint="@color/primary" />

                        <RadioButton
                            android:id="@+id/rb_lock_fit_fit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/fit_fit"
                            android:textColor="@color/text_primary"
                            android:buttonTint="@color/primary" />
                    </RadioGroup>

                    <!-- Checkbox: No recortar (para paralaje / desplazamiento lateral) -->
                    <CheckBox
                        android:id="@+id/cb_lock_crop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/crop_wallpaper"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:buttonTint="@color/primary"
                        android:checked="true"
                        android:layout_marginTop="10dp"
                        android:visibility="visible" />
                </LinearLayout>

                <!-- Tarjeta 4: Brillo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lbl_brightness"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_lock_brightness_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Brillo: 100% (Original)"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp" />

                    <SeekBar
                        android:id="@+id/sb_lock_brightness"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="100"
                        android:thumbTint="@color/secondary"
                        android:progressTint="@color/secondary"
                        android:progressBackgroundTint="@color/card_border" />
                </LinearLayout>

                <!-- Tarjeta 5: Orden de Selección -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lbl_order"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rg_lock_order"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rb_lock_order_random"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/order_random"
                            android:textColor="@color/text_primary"
                            android:buttonTint="@color/primary"
                            android:checked="true" />

                        <RadioButton
                            android:id="@+id/rb_lock_order_sequential"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/order_sequential"
                            android:textColor="@color/text_primary"
                            android:buttonTint="@color/primary" />
                    </RadioGroup>
                </LinearLayout>

                <!-- Tarjeta 6: Mock Phone Live Preview -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card"
                    android:padding="20dp"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lbl_preview"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <FrameLayout
                        android:layout_width="160dp"
                        android:layout_height="290dp"
                        android:background="@drawable/bg_phone_mock"
                        android:padding="6dp">

                        <!-- Contenedor interno redondeado para recortar la imagen de fondo -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:cardCornerRadius="26dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/black">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <!-- La imagen cargada -->
                                <ImageView
                                    android:id="@+id/iv_lock_preview"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    tools:src="@android:drawable/ic_menu_gallery" />

                                <!-- Filtro de atenuación de brillo en tiempo real -->
                                <View
                                    android:id="@+id/view_lock_preview_dim"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@color/black"
                                    android:alpha="0.0" />

                                <!-- Widgets de prueba del mock phone Lockscreen -->
                                <RelativeLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="vertical"
                                        android:gravity="center_horizontal"
                                        android:layout_marginTop="28dp">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="12:00"
                                            android:textColor="@color/white"
                                            android:textSize="26sp"
                                            android:textStyle="bold" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Martes, 2 de Junio"
                                            android:textColor="@color/white"
                                            android:textSize="10sp"
                                            android:alpha="0.8" />
                                    </LinearLayout>

                                    <!-- Icono de candado simulado -->
                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:layout_alignParentBottom="true"
                                        android:layout_centerHorizontal="true"
                                        android:layout_marginBottom="28dp"
                                        android:src="@android:drawable/ic_lock_idle_lock"
                                        app:tint="@color/white" />
                                </RelativeLayout>
                            </FrameLayout>
                        </androidx.cardview.widget.CardView>
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
